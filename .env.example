# grevy-lab environment variables
# Copy this file to .env and adjust values before running `docker compose up`.
# All variables have defaults – this file is only needed to override them.

# ─── Zcash Node Images ───────────────────────────────────────────────────────
# Standard Zebra image used for the ZSA feature-chain node.
ZSA_NODE_IMAGE=zfnd/zebra:latest

# Crosslink prototype image. Switch to shieldedlabs/zebra-crosslink:latest
# once that image is published, or build locally and reference by tag.
CROSSLINK_NODE_IMAGE=zfnd/zebra:latest

# ZSA transaction-generation tool (QEDIT).
ZSA_TX_TOOL_IMAGE=public.ecr.aws/j7v0v6n9/tx-tool:latest

# ─── Port Mappings ────────────────────────────────────────────────────────────
ZSA_P2P_PORT=18233
ZSA_RPC_PORT=18232
ZSA_METRICS_PORT=9999

CROSSLINK_P2P_PORT=18243
CROSSLINK_RPC_PORT=18242
CROSSLINK_METRICS_PORT=9998

# ─── Monitoring Stack ─────────────────────────────────────────────────────────
PROMETHEUS_VERSION=v2.51.2
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=30d

GRAFANA_VERSION=10.4.2
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
# Change this password before exposing Grafana outside localhost!
GRAFANA_ADMIN_PASSWORD=grafana

NODE_EXPORTER_VERSION=v1.7.0
NODE_EXPORTER_PORT=9100
